{
  "name": "windhoox",
  "version": "0.1.0",
  "description": "Windhoox desktop app",
  "private": true,
  "author": "Windhoox",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm build:electron && concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "pnpm build:renderer && pnpm build:electron",
    "build:renderer": "tsc -p tsconfig.json --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac dmg --publish never",
    "dist:win": "pnpm build && electron-builder --win nsis --publish never",
    "test": "vitest run",
    "test:electron": "vitest run src/preload",
    "test:renderer": "vitest run src/renderer",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "sync:docs": "node scripts/sync-docs.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@ant-design/x": "^2.7.0",
    "antd": "^6.4.3",
    "electron-updater": "^6.8.3",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "jsdom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "wait-on": "latest"
  }
}
