{
  "name": "windhoox",
  "version": "0.1.0",
  "description": "Windhoox desktop app",
  "private": true,
  "author": "Windhoox",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "pnpm build:renderer && pnpm build:electron",
    "build:renderer": "tsc -p tsconfig.json --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac dmg --publish never",
    "dist:win": "pnpm build && electron-builder --win nsis --publish never",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "typescript": "latest",
    "vite": "latest",
    "wait-on": "latest"
  }
}
